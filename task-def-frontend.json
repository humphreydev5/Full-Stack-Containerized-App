{
  "family": "frontend-service",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "frontend-container",
      "image": "042655075920.dkr.ecr.eu-north-1.amazonaws.com/gatherly-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/frontend-service",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}
